# KITE Custody Orchestrator – Environment Variables
# Copy to .env and set values. Do not commit .env.

# Server
PORT=3000
NODE_ENV=production

# Admin (Basic auth for Create Organization)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change_me_min_8_chars

# PostgreSQL (organizations)
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_postgres_password

# KITE Custody Vault (must match Vault ALLOWED_API_KEY)
WALLET_SERVICE_URL=http://your-vault-host:8001
WALLET_SERVICE_API_KEY=your-shared-secret-with-vault

# Optional: VAULT_REQUEST_TIMEOUT_MS=30000
